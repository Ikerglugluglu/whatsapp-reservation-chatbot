Options -Indexes
# Reglas de Apache para proteger y enrutar el panel.

RewriteEngine On
RewriteBase /whatsapp-reservation-chatbot/

# Public endpoints (Twilio webhook + public users page)
RewriteRule ^(?:index|usuarios)\.php$ - [L,NC]

# Public assets (if usuarios.php needs CSS/JS)
RewriteRule ^public/ - [L,NC]

# Block internal project directories from direct web access
RewriteRule ^(?:app|docs|scripts|storage|vendor)(?:/|$) - [F,NC]
# Block direct directory browsing and always send to login
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ panel_login.php [L]

# Block sensitive root files from direct web access
RewriteRule ^(?:\.env|config\.php|db\.php|composer\.(?:json|lock))$ panel_login.php [L,NC]

# Allow explicit entrypoints (admin only from allowed IPs)
RewriteRule ^(?:panel_login|panel_logout|panel_register|panel_router|admin)\.php$ - [L,NC]

# Allow API PHP endpoints only (block directory listing)
RewriteRule ^api/?$ - [F,NC]
RewriteRule ^api/.+\.php$ - [L,NC]

# Block any other direct PHP file outside allowed entrypoints/API
RewriteRule \.php$ panel_login.php [L,NC]

# Keep real files working (api/*.php, assets files, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Friendly URL for worker reservations view
RewriteRule ^reservas/?$ usuarios.php [L,QSA]

# Root URL -> login panel
RewriteRule ^$ panel_login.php [L]

# Any unknown route -> login panel
RewriteRule . panel_login.php [L]

# Restrict everything else to the Ayuntamiento IP
RewriteCond %{REMOTE_ADDR} !^2\.136\.236\.45$
RewriteRule ^ - [F]
